COMMAND_PORTAL_RUNTIME_API_BASE_URL=https://nexus-runtime-dev.fly.dev
COMMAND_PORTAL_RUNTIME_READ_TOKEN=<server-only-read-token>
NEXUS_CONTEXT_ASSERTION_SECRET=<shared-runtime-context-assertion-secret-minimum-32-characters>
COMMAND_PORTAL_CONTEXT_PRINCIPAL_ID=command-portal-observer
COMMAND_PORTAL_ALLOWED_ORIGINS=http://localhost:4173
COMMAND_PORTAL_REQUEST_TIMEOUT_MS=8000
COMMAND_PORTAL_REASONING_TIMEOUT_MS=35000
COMMAND_PORTAL_REALTIME_TIMEOUT_MS=25000
COMMAND_PORTAL_CACHE_TTL_MS=15000
COMMAND_PORTAL_MAX_RESPONSE_BYTES=1048576
COMMAND_PORTAL_LOCAL_CAPABILITIES_ENABLED=true
COMMAND_PORTAL_LOCAL_API_BASE_URL=http://127.0.0.1:8765
COMMAND_PORTAL_PLATFORM_RUNTIME_API_BASE_URL=http://127.0.0.1:8080
COMMAND_PORTAL_LOCAL_REQUEST_TIMEOUT_MS=30000
COMMAND_PORTAL_LOCAL_MAX_REQUEST_BYTES=37748736
COMMAND_PORTAL_LOCAL_MAX_RESPONSE_BYTES=5242880

# Operational Replay is independently disabled unless a sanitized Runtime projection is configured.
COMMAND_PORTAL_REPLAY_ENABLED=false
COMMAND_PORTAL_REPLAY_API_BASE_URL=http://127.0.0.1:4317
COMMAND_PORTAL_REPLAY_MAX_RESPONSE_BYTES=26214400

# Hosted Operational Gateway (single-workspace alpha; server-only)
COMMAND_PORTAL_OPERATIONAL_ENABLED=false
COMMAND_PORTAL_OPERATIONAL_API_BASE_URL=https://nexus-operations.example.com
COMMAND_PORTAL_OPERATIONAL_RUNTIME_TOKEN=<shared-server-runtime-token-minimum-24-characters>
COMMAND_PORTAL_SESSION_SECRET=<random-session-signing-secret-minimum-32-characters>
COMMAND_PORTAL_OPERATOR_ACCESS_KEY=<single-operator-bootstrap-key-minimum-16-characters>
COMMAND_PORTAL_OPERATOR_USER_ID=operator-alpha
COMMAND_PORTAL_TENANT_ID=nexicron
COMMAND_PORTAL_WORKSPACE_ID=primary
COMMAND_PORTAL_OPERATOR_ROLE=admin
COMMAND_PORTAL_OPERATIONAL_SCOPES=operations:read,operations:write,actions:simulate,actions:execute,approvals:decide,evidence:write
COMMAND_PORTAL_SESSION_TTL_SECONDS=3600
COMMAND_PORTAL_COOKIE_SECURE=true

# Configure these matching values on the execution Runtime, not in the portal process.
# The current single-operator compatibility boundary requires exact identity, role, and scope binding.
# NEXUS_HOSTED_SERVICE_ID must equal COMMAND_PORTAL_OPERATOR_USER_ID.
# NEXUS_HOSTED_SERVICE_ROLE must equal COMMAND_PORTAL_OPERATOR_ROLE.
# NEXUS_HOSTED_SERVICE_SCOPES must equal COMMAND_PORTAL_OPERATIONAL_SCOPES.
# Example Runtime values:
# NEXUS_HOSTED_SERVICE_ID=operator-alpha
# NEXUS_HOSTED_SERVICE_ROLE=admin
# NEXUS_HOSTED_SERVICE_SCOPES=operations:read,operations:write,actions:simulate,actions:execute,approvals:decide,evidence:write
PORT=4173

# Runtime configuration is server-only. Local capability mode accepts loopback targets only.
# Never define a VITE_ Runtime variable or credential.
